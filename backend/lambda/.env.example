# アプリケーション設定
APP_ENV=development
LOG_LEVEL=INFO

# AWS設定
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# DynamoDB設定
DYNAMODB_TABLE_NAME=devices
DYNAMODB_ENDPOINT_URL=http://localhost:8000  # ローカル開発用

# API Gateway設定
API_GATEWAY_ENDPOINT=your-api-gateway-endpoint

# データベース設定
DB_TYPE=rds

# MySQL設定（ローカル開発用）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_local_password
DB_NAME=lambdadb

# MySQL設定（本番環境用）
RDS_HOST=your-rds-endpoint.region.rds.amazonaws.com
RDS_PORT=3306
RDS_USER=your_rds_user
RDS_PASSWORD=your_rds_password
RDS_DATABASE=lambdadb

# 接続プール設定
DB_POOL_SIZE=5 